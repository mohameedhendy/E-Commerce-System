POSTGRES_DB=ecommerce_db
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_PORT=5433

BACKEND_PORT=8080
FRONTEND_URL=http://localhost:3000

JWT_SECRET=replace-with-a-random-secret-containing-at-least-32-characters
JWT_ISSUER=eCommerce
JWT_AUDIENCE=ecommerce-api
JWT_EXPIRY_SECONDS=604800
JWT_REFRESH_EXPIRY_SECONDS=2592000
JWT_VERIFICATION_EXPIRY_SECONDS=86400
JWT_PASSWORD_RESET_EXPIRY_SECONDS=1800

AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_MAX_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60