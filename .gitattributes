# Normalize text files across Windows, Linux and CI
* text=auto
.gitattributes text eol=lf

# Linux and container executable files
mvnw text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf

# Project source and configuration files
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.sql text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.json text eol=lf

# Windows command files
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.jar binary
